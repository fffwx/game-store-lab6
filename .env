# Змінні середовища для Game Store

# Середовище запуску
ENVIRONMENT=development

# Налаштування бази даних
DATABASE_URL=postgresql://game_user:game_pass@localhost:5432/game_store
POSTGRES_USER=game_user
POSTGRES_PASSWORD=game_pass
POSTGRES_DB=game_store

# Налаштування додатку
APP_NAME=Game Store
DEBUG=True
LOG_LEVEL=INFO

# Бонус при реєстрації (грн)
REGISTRATION_BONUS=100

# Термін повернення (днів)
RETURN_DAYS_LIMIT=14

# Docker налаштування
DOCKER_IMAGE=game-store
DOCKER_TAG=latest